# ============================================================
# Variáveis de ambiente — Trading Bot B3  (EXEMPLO)
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# O arquivo .env está no .gitignore e NUNCA deve ser commitado.
# ============================================================

# --- brapi.dev (https://brapi.dev) ---
BRAPI_TOKEN=SEU_TOKEN_BRAPI_AQUI

# --- Cedro Technologies (preencher após contato comercial) ---
CEDRO_API_KEY=
CEDRO_API_SECRET=

# --- Telegram (opcional, para notificações) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Anthropic Claude (Módulo 7) ---
ANTHROPIC_API_KEY=

# --- Dashboard Emergency Stop ---
# Defina uma senha forte aqui. NUNCA use "meridian2026" ou deixe em branco em produção.
EMERGENCY_PASSWORD=troque_para_uma_senha_forte_aqui

# --- IA (Módulo 7 — Comitê de Agentes) ---
# Provedor principal: Google Gemini (obrigatório para o comitê de IA)
GEMINI_API_KEY=sua_chave_gemini_aqui

# Provedor de fallback: OpenAI (opcional — assume se Gemini falhar)
OPENAI_API_KEY=sua_chave_openai_aqui
