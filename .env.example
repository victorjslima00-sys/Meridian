# ==============================================================================
# 🔐 Meridian Enterprise — Configurações de Ambiente (SECRETS)
# ==============================================================================
# ATENÇÃO: NUNCA COMMIT ESTE ARQUIVO (nem o .env) PARA O GITHUB!
# Copie este arquivo para ".env" e preencha as variáveis abaixo.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CEDRO TECHNOLOGIES (Corretora e Market Data)
# ------------------------------------------------------------------------------
# A Cedro é a API utilizada para acesso à B3. Obtenha essas chaves entrando em 
# contato com comercial@cedrotech.com
CEDRO_API_KEY="sua_api_key_aqui"
CEDRO_SECRET="seu_api_secret_aqui"
CEDRO_ACCOUNT="numero_da_sua_conta"

# Qual ambiente usar na Cedro? (homologacao ou producao)
# Sempre use "homologacao" primeiro para testar suas estratégias.
CEDRO_ENV="homologacao" 

# ------------------------------------------------------------------------------
# 2. BRAPI.DEV (Market Data Alternativo para Fase 0)
# ------------------------------------------------------------------------------
# Usado apenas para puxar histórico longo. Obtenha em brapi.dev
BRAPI_TOKEN="seu_token_brapi_aqui"

# ------------------------------------------------------------------------------
# 3. LLM API KEYS (IA Generativa)
# ------------------------------------------------------------------------------
# Cadeia de fallback: o bot tenta cada provedor abaixo, na ordem, e só
# cai pra HOLD (fail-closed) se TODOS os configurados falharem. Só
# precisa de UMA chave pra funcionar (Gemini); as demais são opcionais,
# e cada uma só entra na cadeia se sua variável estiver preenchida.

# 1º da cadeia: Google Gemini (tier gratuito é bem restrito — 500 req/dia
# no gemini-3.1-flash-lite, 15 req/min — ver BACKLOG.md)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="sua_chave_gemini_aqui"

# 2º da cadeia: Groq (tier gratuito generoso — 14.400 req/dia no
# llama-3.1-8b-instant, sem cartão de crédito)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=""

# 3º da cadeia: Cerebras (mesmo teto do Groq — 14.400 req/dia — mas com
# o gpt-oss-120b, um modelo bem maior/melhor)
# Obtenha em: https://cloud.cerebras.ai/platform/
CEREBRAS_API_KEY=""

# 4º da cadeia: GitHub Models (usa sua conta GitHub já existente — gere
# um Personal Access Token fine-grained com a permissão "Models: Read")
# Gere em: https://github.com/settings/personal-access-tokens
GITHUB_MODELS_TOKEN=""

# 5º da cadeia (último fallback): OpenAI, se você tiver créditos reais
OPENAI_API_KEY=""

# Não usado pela cadeia de LLM hoje (Claude Pro ≠ acesso à API da
# Anthropic — são produtos separados; deixe vazio a menos que você tenha
# créditos de API de verdade em console.anthropic.com)
ANTHROPIC_API_KEY=""

# ------------------------------------------------------------------------------
# 4. TELEGRAM (Alertas de Risco)
# ------------------------------------------------------------------------------
# Crie um bot no BotFather e obtenha o token.
TELEGRAM_BOT_TOKEN="seu_bot_token"
TELEGRAM_CHAT_ID="seu_chat_id"

# ------------------------------------------------------------------------------
# 5. API E DASHBOARD
# Gere um segredo forte (por exemplo: python -c "import secrets; print(secrets.token_urlsafe(32))")
API_KEY="substitua-por-um-segredo-forte"
EMERGENCY_PASSWORD="substitua-por-outro-segredo-forte"

# CORS
# ------------------------------------------------------------------------------
# Em produção: coloque o IP/domínio real do seu servidor frontend
# Exemplo: ALLOWED_ORIGINS=https://meu-meridian.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
