# ==============================================================================
# 🔐 Meridian Enterprise — Configurações de Ambiente (SECRETS)
# ==============================================================================
# ATENÇÃO: NUNCA COMMIT ESTE ARQUIVO (nem o .env) PARA O GITHUB!
# Copie este arquivo para ".env" e preencha as variáveis abaixo.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CEDRO TECHNOLOGIES (Corretora e Market Data)
# ------------------------------------------------------------------------------
# A Cedro é a API utilizada para acesso à B3. Obtenha essas chaves entrando em 
# contato com comercial@cedrotech.com
CEDRO_API_KEY="sua_api_key_aqui"
CEDRO_SECRET="seu_api_secret_aqui"
CEDRO_ACCOUNT="numero_da_sua_conta"

# Qual ambiente usar na Cedro? (homologacao ou producao)
# Sempre use "homologacao" primeiro para testar suas estratégias.
CEDRO_ENV="homologacao" 

# ------------------------------------------------------------------------------
# 2. BRAPI.DEV (Market Data Alternativo para Fase 0)
# ------------------------------------------------------------------------------
# Usado apenas para puxar histórico longo. Obtenha em brapi.dev
BRAPI_TOKEN="seu_token_brapi_aqui"

# ------------------------------------------------------------------------------
# 3. LLM API KEYS (IA Generativa)
# ------------------------------------------------------------------------------
# Chave primária: Google Gemini (OBRIGATÓRIA para o Comitê de Agentes IA)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="sua_chave_gemini_aqui"

# Fallback secundário: OpenAI (opcional — usado se Gemini falhar)
OPENAI_API_KEY=""

# Fallback terciário: Anthropic Claude (Módulo 7 — análise profunda)
ANTHROPIC_API_KEY=""

# ------------------------------------------------------------------------------
# 4. TELEGRAM (Alertas de Risco)
# ------------------------------------------------------------------------------
# Crie um bot no BotFather e obtenha o token.
TELEGRAM_BOT_TOKEN="seu_bot_token"
TELEGRAM_CHAT_ID="seu_chat_id"
