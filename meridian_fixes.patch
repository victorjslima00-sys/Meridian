index 4c99ef7..ef246b6 100644
--- a/tests/test_signals.py
+++ b/tests/test_signals.py
@@ -1,7 +1,88 @@
 import pytest
 import pandas as pd
 import numpy as np
-from trading_bot.signals.engine import _rsi, _sma, _volume_ratio
+from datetime import date, timedelta
+from trading_bot.signals.engine import _rsi, _sma, _volume_ratio, compute_signal
+
+
+def _make_price_history(n_days=200, seed=42, start_price=80.0, drift=0.0006, vol=0.011):
+    """
+    Gera um histórico OHLCV sintético com um random walk realista (ruído +
+    leve tendência), evitando o problema de RSI saturar em 100/0 quando a
+    série só sobe ou só desce artificialmente. Usado como base de 200 dias
+    (mínimo exigido pela SMA-200) para os testes de compute_signal.
+    """
+    rng = np.random.default_rng(seed)
+    rows = []
+    d = date(2023, 1, 2)
+    price = start_price
+    n = 0
+    while n < n_days:
+        if d.weekday() < 5:
+            price = max(price * (1 + rng.normal(drift, vol)), 1.0)
+            rows.append({
+                "ts": d, "o": price, "h": price * 1.008, "l": price * 0.992,
+                "c": price, "adj_close": price, "v": int(rng.normal(500_000, 50_000)),
+            })
+            n += 1
+        d += timedelta(days=1)
+    return rows, d
+
+
+def test_compute_signal_detects_breakout():
+    """
+    Exemplo/hipótese: um dia com fechamento 3% acima da máxima Donchian(20),
+    volume 2.5x a média e RSI dentro da faixa deve gerar um Candidate válido.
+    Este cenário (compute_signal) estava com 0% de cobertura antes deste teste.
+    """
+    rows, next_day = _make_price_history()
+    while next_day.weekday() >= 5:
+        next_day += timedelta(days=1)
+
+    last_close = rows[-1]["c"]
+    donchian_high = max(r["h"] for r in rows[-20:])
+    breakout_price = donchian_high * 1.03
+    rows.append({
+        "ts": next_day, "o": last_close, "h": breakout_price * 1.01,
+        "l": last_close * 0.99, "c": breakout_price, "adj_close": breakout_price,
+        "v": 1_300_000,
+    })
+    df = pd.DataFrame(rows)
+
+    cand = compute_signal(df, "TESTE3")
+
+    assert cand is not None
+    assert cand.entry_price > donchian_high
+    assert cand.stop < cand.entry_price < cand.target
+    assert 50 <= cand.rsi <= 75
+    assert cand.volume_ratio >= 2.0
+
+
+def test_compute_signal_no_breakout_returns_none():
+    """Sem breakout (dia normal de random walk), compute_signal deve retornar None."""
+    rows, next_day = _make_price_history()
+    while next_day.weekday() >= 5:
+        next_day += timedelta(days=1)
+
+    # Dia comum: variação pequena, não configura breakout de 20 dias
+    last_close = rows[-1]["c"]
+    rows.append({
+        "ts": next_day, "o": last_close, "h": last_close * 1.002,
+        "l": last_close * 0.998, "c": last_close * 1.001, "adj_close": last_close * 1.001,
+        "v": 480_000,
+    })
+    df = pd.DataFrame(rows)
+
+    cand = compute_signal(df, "TESTE3")
+
+    assert cand is None
+
+
+def test_compute_signal_insufficient_history_returns_none():
+    """Menos de 200 dias de histórico (mínimo p/ SMA-200) deve retornar None, não lançar exceção."""
+    rows, _ = _make_price_history(n_days=50)
+    df = pd.DataFrame(rows)
+    assert compute_signal(df, "TESTE3") is None
 
