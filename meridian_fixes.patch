diff --git a/tests/test_storage.py b/tests/test_storage.py
new file mode 100644
index 0000000..1ea5d9d
--- /dev/null
+++ b/tests/test_storage.py
@@ -0,0 +1,69 @@
+import pandas as pd
+from datetime import date
+from trading_bot.data import storage
+
+
+def _sample_df(ticker="PETR4"):
+    return pd.DataFrame([
+        {"ticker": ticker, "ts": date(2024, 1, 2), "o": 10.0, "h": 11.0, "l": 9.0, "c": 10.5, "v": 1000.0, "adj_close": 10.5},
+        {"ticker": ticker, "ts": date(2024, 1, 3), "o": 10.5, "h": 11.0, "l": 10.0, "c": 10.8, "v": 1200.0, "adj_close": 10.8},
+    ])
+
+
+def test_save_and_load_round_trip(tmp_path):
+    db_path = str(tmp_path / "test.db")
+    storage.initialize_db(db_path)
+
+    inserted = storage.save_ohlcv(_sample_df(), source="yfinance", db_path=db_path)
+    assert inserted == 2
+
+    loaded = storage.load_ohlcv("PETR4", db_path=db_path)
+    assert len(loaded) == 2
+    assert list(loaded["ts"]) == [date(2024, 1, 2), date(2024, 1, 3)]
+    assert loaded["c"].iloc[-1] == 10.8
+
+
+def test_save_ohlcv_ignores_duplicates(tmp_path):
+    """INSERT OR IGNORE: salvar o mesmo (ticker, ts) duas vezes não deve duplicar nem lançar erro."""
+    db_path = str(tmp_path / "test.db")
+    storage.initialize_db(db_path)
+
+    storage.save_ohlcv(_sample_df(), db_path=db_path)
+    inserted_again = storage.save_ohlcv(_sample_df(), db_path=db_path)
+
+    assert inserted_again == 0
+    loaded = storage.load_ohlcv("PETR4", db_path=db_path)
+    assert len(loaded) == 2  # não duplicou
+
+
+def test_load_ohlcv_empty_ticker_returns_empty_df(tmp_path):
+    db_path = str(tmp_path / "test.db")
+    storage.initialize_db(db_path)
+    loaded = storage.load_ohlcv("INEXISTENTE", db_path=db_path)
+    assert loaded.empty
+
+
+def test_get_last_date(tmp_path):
+    db_path = str(tmp_path / "test.db")
+    storage.initialize_db(db_path)
+    storage.save_ohlcv(_sample_df(), db_path=db_path)
+
+    assert storage.get_last_date("PETR4", db_path=db_path) == date(2024, 1, 3)
+    assert storage.get_last_date("SEM_DADOS", db_path=db_path) is None
+
+
+def test_get_missing_tickers(tmp_path):
+    db_path = str(tmp_path / "test.db")
+    storage.initialize_db(db_path)
+    storage.save_ohlcv(_sample_df("PETR4"), db_path=db_path)
+
+    missing = storage.get_missing_tickers(
+        ["PETR4", "VALE3"], required_start=date(2024, 1, 1), db_path=db_path
+    )
+    assert missing == ["VALE3"]
+
+    # PETR4 só tem dado até 2024-01-03: exigir a partir de 2024-06-01 deve marcá-lo como "faltando" também
+    missing_strict = storage.get_missing_tickers(
+        ["PETR4"], required_start=date(2024, 6, 1), db_path=db_path
+    )
+    assert missing_strict == ["PETR4"]
